            <div class="urgent">
                <strong>URGENT: This alert requires immediate security team attention</strong>
            </div>
            
            {{ range .Alerts }}
            <div class="security-alert">
                <h2>{{ .Annotations.summary }}</h2>
                <p>{{ .Annotations.description }}</p>
                <p><strong>Category:</strong> {{ .Labels.category }}</p>
                <p><strong>Detected:</strong> {{ .StartsAt.Format "2006-01-02 15:04:05 UTC" }}</p>
