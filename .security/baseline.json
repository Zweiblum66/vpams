{
  "version": "1.0.0",
  "security_baseline": {
    "authentication": {
      "jwt_expiration_minutes": 60,
      "refresh_token_expiration_days": 7,
      "password_min_length": 12,
      "password_require_uppercase": true,
      "password_require_lowercase": true,
      "password_require_numbers": true,
      "password_require_special": true,
      "password_history_count": 5,
      "max_login_attempts": 5,
      "lockout_duration_minutes": 30,
      "mfa_required_for_admins": true
    },
    "encryption": {
      "algorithm": "AES-256-GCM",
      "key_rotation_days": 90,
      "tls_min_version": "1.3",
      "allowed_ciphers": [
        "TLS_AES_256_GCM_SHA384",
        "TLS_AES_128_GCM_SHA256",
        "TLS_CHACHA20_POLY1305_SHA256"
      ]
    },
    "api_security": {
      "rate_limit_per_minute": 100,
      "rate_limit_per_hour": 1000,
      "max_request_size_mb": 100,
      "request_timeout_seconds": 30,
      "cors_allowed_origins": ["https://app.mams.com"],
      "api_key_length": 32,
      "require_api_versioning": true
    },
    "session_management": {
      "session_timeout_minutes": 30,
      "session_renewal_percentage": 80,
      "concurrent_sessions_allowed": 3,
      "session_token_length": 64
    },
    "data_protection": {
      "pii_fields_encrypted": true,
      "data_retention_days": 365,
      "backup_encryption_required": true,
      "audit_log_retention_days": 730,
      "gdpr_compliant": true
    },
    "file_security": {
      "allowed_file_extensions": [
        ".mp4", ".mov", ".avi", ".mkv",
        ".jpg", ".jpeg", ".png", ".gif",
        ".mp3", ".wav", ".flac",
        ".pdf", ".doc", ".docx"
      ],
      "max_file_size_gb": 50,
      "virus_scan_required": true,
      "quarantine_suspicious_files": true
    },
    "container_security": {
      "run_as_non_root": true,
      "read_only_root_filesystem": true,
      "no_new_privileges": true,
      "drop_capabilities": ["ALL"],
      "security_scan_on_build": true,
      "base_image_max_age_days": 30
    },
    "network_security": {
      "internal_services_not_exposed": true,
      "use_network_policies": true,
      "ingress_rate_limiting": true,
      "egress_filtering": true,
      "service_mesh_enabled": true
    },
    "monitoring": {
      "security_event_retention_days": 90,
      "alert_on_suspicious_activity": true,
      "log_failed_auth_attempts": true,
      "track_privileged_actions": true,
      "anomaly_detection_enabled": true
    },
    "compliance": {
      "standards": ["ISO27001", "SOC2", "GDPR"],
      "audit_frequency_days": 90,
      "penetration_test_frequency_days": 180,
      "vulnerability_scan_frequency_days": 7,
      "security_training_required": true
    }
  },
  "security_controls": {
    "preventive": [
      "Input validation",
      "Authentication checks",
      "Authorization controls",
      "Encryption at rest",
      "Secure communication"
    ],
    "detective": [
      "Security monitoring",
      "Audit logging",
      "Intrusion detection",
      "File integrity monitoring",
      "Vulnerability scanning"
    ],
    "corrective": [
      "Incident response plan",
      "Automated patching",
      "Backup and recovery",
      "Security updates",
      "Access revocation"
    ]
  },
  "excluded_from_scanning": [
    "tests/",
    "docs/",
    ".git/",
    "node_modules/",
    "venv/",
    ".venv/"
  ],
  "suppressed_vulnerabilities": {
    "example": {
      "cve": "CVE-YYYY-XXXXX",
      "reason": "False positive - not applicable to our use case",
      "expires": "2024-12-31"
    }
  }
}