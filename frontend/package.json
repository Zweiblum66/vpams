    "cypress": "^15.9.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.0",
    "mochawesome-report-generator": "^6.3.2",
    "prettier": "^3.8.0",
    "serve": "^14.2.5",
    "wait-on": "^9.0.3"
  },
  "proxy": "http://localhost:8001"
}
