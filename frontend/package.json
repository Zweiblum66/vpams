    "cypress": "^13.6.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "prettier": "^3.1.0",
    "serve": "^14.2.1",
    "wait-on": "^7.2.0"
  },
  "proxy": "http://localhost:8001"
}
