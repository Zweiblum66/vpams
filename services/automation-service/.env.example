# Service Configuration
SERVICE_NAME=automation-service
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8015
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=development

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/mams_automation
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis Configuration
REDIS_URL=redis://redis:6379/4

# Authentication
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Device Discovery
ENABLE_AUTO_DISCOVERY=true
DISCOVERY_INTERVAL=300
DISCOVERY_TIMEOUT=30
DISCOVERY_PROTOCOLS=mdns,ssdp,ember,ndi

# Protocol Settings
DEFAULT_CONTROL_PROTOCOL=tcp
CONTROL_TIMEOUT=5
COMMAND_RETRY_COUNT=3
HEARTBEAT_INTERVAL=10
MAX_COMMAND_QUEUE_SIZE=1000

# Switcher Configuration
SWITCHER_ENABLED=true
DEFAULT_SWITCHER_TYPE=ross
SWITCHER_CONNECTION_POOL_SIZE=5
SWITCHER_COMMAND_DELAY_MS=10

# Camera Configuration
CAMERA_ENABLED=true
DEFAULT_CAMERA_PROTOCOL=visca
PTZ_SPEED_SCALE=1.0
PRESET_RECALL_TIMEOUT=10
CAMERA_HOME_ON_STARTUP=true
MAX_PTZ_SPEED=24

# Audio Configuration
AUDIO_ENABLED=true
DEFAULT_AUDIO_PROTOCOL=ember
AUDIO_FADE_CURVE=linear
DEFAULT_CROSSFADE_TIME=1000
AUDIO_METER_INTERVAL=100

# Graphics Configuration
GRAPHICS_ENABLED=true
DEFAULT_GRAPHICS_PROTOCOL=viz
TEMPLATE_CACHE_SIZE=100
GRAPHICS_PREVIEW_ENABLED=true

# Lighting Configuration
LIGHTING_ENABLED=true
DEFAULT_LIGHTING_PROTOCOL=artnet
DMX_UNIVERSE_COUNT=4
LIGHTING_FADE_TIME=1000

# Show Control
SHOW_CONTROL_ENABLED=true
CUE_PRELOAD_COUNT=5
EMERGENCY_STOP_GPI=16
REHEARSAL_MODE_DEFAULT=false

# Macro Engine
MACRO_ENABLED=true
MAX_MACRO_ACTIONS=1000
MACRO_EXECUTION_TIMEOUT=300
MACRO_STORAGE_PATH=/data/macros

# Remote Production
REMOTE_CONTROL_ENABLED=true
CONTROL_LATENCY_COMPENSATION=true
MAX_CONTROL_LATENCY_MS=200
REMOTE_PREVIEW_QUALITY=medium

# Virtual Production
VIRTUAL_PRODUCTION_ENABLED=false
TRACKING_SYSTEM=freed
RENDER_ENGINE=unreal

# Monitoring & Alerts
ENABLE_DEVICE_MONITORING=true
MONITORING_INTERVAL=5
ALERT_ON_DEVICE_FAILURE=true
ALERT_WEBHOOK_URL=
DEVICE_TIMEOUT_SECONDS=30

# Performance Settings
MAX_CONCURRENT_COMMANDS=100
COMMAND_BUFFER_SIZE=10000
ENABLE_COMMAND_BATCHING=true
BATCH_WINDOW_MS=50

# Security Settings
DEVICE_AUTH_REQUIRED=true
ENCRYPT_CONTROL_TRAFFIC=true
COMMAND_AUTHORIZATION=true
EMERGENCY_OVERRIDE_PIN=

# Development Settings
DEVELOPMENT_MODE=false
SIMULATE_DEVICES=false
LOG_DEVICE_COMMANDS=false