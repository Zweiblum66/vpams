# Security Certification Service Configuration

# Service Configuration
SERVICE_NAME=security-certification
SERVICE_PORT=8010
LOG_LEVEL=INFO
DEBUG=false

# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mams_security
MONGODB_URL=mongodb://localhost:27017/mams_security
REDIS_URL=redis://localhost:6379/5

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# External Security Tools
NMAP_PATH=/usr/bin/nmap
OPENVAS_HOST=localhost
OPENVAS_PORT=9390
OPENVAS_USERNAME=admin
OPENVAS_PASSWORD=admin

# Security Scanning Configuration
MAX_SCAN_TARGETS=50
SCAN_TIMEOUT_MINUTES=120
MAX_CONCURRENT_SCANS=5

# SSL/TLS Configuration
SSL_VERIFY=true
SSL_CERT_CHECK_ENABLED=true

# Compliance Configuration
COMPLIANCE_CACHE_TTL=3600
AUDIT_RETENTION_DAYS=2555

# Report Generation
REPORT_STORAGE_PATH=/tmp/security-reports
MAX_REPORT_SIZE_MB=100

# Notification Configuration
NOTIFICATION_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=

# External Integrations
VULNERABILITY_DB_URL=https://cve.circl.lu/api/
SECURITY_ADVISORIES_URL=https://api.github.com/advisories

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=200

# Feature Flags
ENABLE_AUTOMATED_SCANNING=true
ENABLE_VULN_CORRELATION=true
ENABLE_COMPLIANCE_AUTOMATION=true
ENABLE_RISK_SCORING=true

# Advanced Security Features
ENABLE_THREAT_INTELLIGENCE=false
THREAT_INTEL_API_KEY=
ENABLE_DEVSECOPS=true