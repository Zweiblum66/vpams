# Service Configuration
PROXY_SERVICE_NAME=proxy-generation-service
PROXY_SERVICE_VERSION=1.0.0
PROXY_ENVIRONMENT=development
PROXY_DEBUG=true
PROXY_SERVICE_PORT=8008

# Database
PROXY_DATABASE_URL=postgresql+asyncpg://mams:dev_password@postgres:5432/mams_proxy
PROXY_REDIS_URL=redis://redis:6379/0

# Message Queue
PROXY_RABBITMQ_URL=amqp://mams:dev_password@rabbitmq:5672/
PROXY_PROXY_QUEUE_NAME=proxy_generation_queue
PROXY_MAX_CONCURRENT_JOBS=4

# Storage
PROXY_STORAGE_BACKEND=s3
PROXY_S3_ENDPOINT=http://minio:9000
PROXY_S3_ACCESS_KEY=minioadmin
PROXY_S3_SECRET_KEY=minioadmin
PROXY_S3_BUCKET_NAME=mams-proxies
PROXY_S3_REGION=us-east-1

# Local storage fallback
PROXY_LOCAL_STORAGE_PATH=/app/storage/proxies

# FFmpeg Configuration
PROXY_FFMPEG_PATH=ffmpeg
PROXY_FFPROBE_PATH=ffprobe
PROXY_FFMPEG_THREADS=0
PROXY_ENABLE_GPU_ACCELERATION=false
PROXY_GPU_DEVICE=

# Processing Limits
PROXY_MAX_FILE_SIZE=53687091200
PROXY_PROCESSING_TIMEOUT=3600
PROXY_MAX_RETRIES=3
PROXY_RETRY_DELAY=60

# Monitoring
PROXY_ENABLE_METRICS=true
PROXY_METRICS_PORT=9090

# JWT Settings
PROXY_JWT_SECRET_KEY=your-secret-key-here
PROXY_JWT_ALGORITHM=HS256
PROXY_JWT_EXPIRATION_MINUTES=60