# Application
SECRET_KEY=your-secret-key-here
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://mams:mams_password@localhost:5432/customer_portal

# Redis
REDIS_URL=redis://localhost:6379/4

# Service URLs
AUTH_SERVICE_URL=http://localhost:8001
BILLING_SERVICE_URL=http://localhost:8015
SUPPORT_SERVICE_URL=http://localhost:8016
STORAGE_SERVICE_URL=http://localhost:8002

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://portal.mams.com

# Email Configuration
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
FROM_EMAIL=noreply@mams.com
FROM_NAME=MAMS Support

# Features
ENABLE_LIVE_CHAT=true
ENABLE_COMMUNITY_FORUM=true
ENABLE_SELF_SERVICE_UPGRADE=true
ENABLE_METRICS=true

# External Services
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
INTERCOM_APP_ID=your-intercom-app-id
KNOWLEDGE_BASE_URL=https://kb.mams.com

# Security
JWT_SECRET_KEY=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000