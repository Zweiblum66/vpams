# Disaster Recovery Service Configuration

# Service configuration
SERVICE_NAME=disaster-recovery
SERVICE_PORT=8014
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/mams_dr

# Redis
REDIS_URL=redis://localhost:6379/9

# Storage (S3-compatible)
BACKUP_BUCKET=mams-backups
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1

# Security
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Disaster Recovery Settings
DEFAULT_RTO_CRITICAL_MINUTES=60
DEFAULT_RTO_HIGH_MINUTES=240
DEFAULT_RTO_MEDIUM_MINUTES=1440
DEFAULT_RTO_LOW_MINUTES=4320

DEFAULT_RPO_CRITICAL_MINUTES=15
DEFAULT_RPO_HIGH_MINUTES=60
DEFAULT_RPO_MEDIUM_MINUTES=240
DEFAULT_RPO_LOW_MINUTES=1440

# Backup Settings
BACKUP_RETENTION_DAYS_DEFAULT=30
BACKUP_COMPRESSION_ENABLED=true
BACKUP_ENCRYPTION_ENABLED=true
BACKUP_VERIFICATION_ENABLED=true
BACKUP_MAX_CONCURRENT=5

# Failover Settings
FAILOVER_HEALTH_CHECK_INTERVAL_SECONDS=30
FAILOVER_AUTO_THRESHOLD_DEFAULT=3
FAILOVER_NOTIFICATION_CHANNELS=["email","slack"]

# Recovery Testing
TEST_ENVIRONMENT_PREFIX=dr-test
TEST_DATA_SAMPLE_PERCENTAGE=10.0
TEST_NOTIFICATION_ENABLED=true

# Monitoring
MONITORING_ENABLED=true
METRICS_RETENTION_DAYS=90
ALERT_THRESHOLD_RTO_PERCENTAGE=80.0
ALERT_THRESHOLD_RPO_PERCENTAGE=80.0

# Notification Settings (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=dr-alerts@mams.example.com

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/YOUR/WEBHOOK/URL
PAGERDUTY_API_KEY=your-pagerduty-api-key

# External Services (Optional)
PROMETHEUS_METRICS_ENABLED=true
GRAFANA_API_URL=http://localhost:3000
GRAFANA_API_KEY=your-grafana-api-key

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100