# Search Engine Service Configuration

# Service Settings
SERVICE_NAME=search-engine
SERVICE_PORT=8006
DEBUG=false
LOG_LEVEL=INFO

# OpenSearch Configuration
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_SCHEME=http
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_SSL_VERIFY=false
OPENSEARCH_SSL_CERT_PATH=
OPENSEARCH_TIMEOUT=30
OPENSEARCH_MAX_RETRIES=3

# Index Configuration
ASSETS_INDEX_NAME=mams_assets
METADATA_INDEX_NAME=mams_metadata
CONTENT_INDEX_NAME=mams_content
LOGS_INDEX_NAME=mams_search_logs

# Search Configuration
DEFAULT_SEARCH_SIZE=20
MAX_SEARCH_SIZE=1000
SEARCH_TIMEOUT=30
ENABLE_SEARCH_SUGGESTIONS=true
ENABLE_SEARCH_ANALYTICS=true

# Feature Flags
ENABLE_SEMANTIC_SEARCH=false
ENABLE_ML_RANKING=false
ENABLE_AUTO_COMPLETE=true

# Performance Settings
BULK_INDEX_SIZE=100
REFRESH_INTERVAL=1s
NUMBER_OF_SHARDS=1
NUMBER_OF_REPLICAS=0

# Security
API_KEY_HEADER=X-API-Key
ALLOWED_ORIGINS=*

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090