# Billing Service Configuration

# Service Info
SERVICE_NAME=billing-service
SERVICE_VERSION=1.0.0
DEBUG=false

# Server Configuration
HOST=0.0.0.0
PORT=8015
WORKERS=4

# Database Configuration
DATABASE_URL=postgresql+asyncpg://mams_user:your_password@postgres:5432/mams_billing
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis Configuration
REDIS_URL=redis://redis:6379/5
REDIS_MAX_CONNECTIONS=50

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# PayPal Configuration
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
PAYPAL_MODE=sandbox

# Tax Services (Optional)
TAXJAR_API_KEY=your_taxjar_api_key
AVALARA_ACCOUNT_ID=your_avalara_account_id
AVALARA_LICENSE_KEY=your_avalara_license_key

# Email Configuration
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
SMTP_TLS=true
EMAIL_FROM=billing@mams.io

# Features
ENABLE_USAGE_BILLING=true
ENABLE_MULTI_CURRENCY=true
ENABLE_TAX_CALCULATION=true
ENABLE_DUNNING=true
ENABLE_METRICS=true

# Webhooks
WEBHOOK_RETRY_COUNT=3
WEBHOOK_TIMEOUT=30
WEBHOOK_SECRET=your-webhook-secret-key

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Monitoring (Optional)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Service URLs
USER_SERVICE_URL=http://user-management:8001
NOTIFICATION_SERVICE_URL=http://notification:8016