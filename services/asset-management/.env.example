# Asset Management Service Configuration

# Service Settings
SERVICE_NAME=asset-management
SERVICE_PORT=8003
ENVIRONMENT=development
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://mams:mams@localhost:5432/mams_assets
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Storage Service
STORAGE_SERVICE_URL=http://localhost:8002
STORAGE_SERVICE_TIMEOUT=30
DEFAULT_STORAGE_DRIVER=local

# User Management Service
USER_SERVICE_URL=http://localhost:8001

# File Processing
MAX_UPLOAD_SIZE=10737418240  # 10GB
CHUNK_SIZE=5242880  # 5MB

# Asset Processing
ENABLE_VIRUS_SCAN=true
ENABLE_DUPLICATE_DETECTION=true
AUTO_GENERATE_THUMBNAILS=true
AUTO_EXTRACT_METADATA=true

# Virus Scanning
# Leave empty to use only ClamAV (if available)
# Set to use VirusTotal or other cloud scanners
VIRUS_SCAN_API_URL=
VIRUS_SCAN_API_KEY=

# Versioning
MAX_VERSIONS_PER_ASSET=10
AUTO_ARCHIVE_OLD_VERSIONS=true

# Security
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# API Settings
API_PREFIX=/api/v1
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Caching
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS
CORS_ORIGINS=["*"]

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090