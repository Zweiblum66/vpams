# Metadata Service Configuration

# Service Info
SERVICE_NAME=metadata-service
SERVICE_PORT=8005
DEBUG=false
LOG_LEVEL=INFO

# MongoDB Configuration
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DATABASE=mams_metadata
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=1

# Redis Configuration (for caching)
REDIS_URL=redis://redis:6379/0
CACHE_TTL=3600

# Authentication
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# CORS Origins (comma-separated)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Service Integration URLs
STORAGE_SERVICE_URL=http://storage-service:8003
ASSET_SERVICE_URL=http://asset-management:8004
SEARCH_SERVICE_URL=http://search-engine:8006

# Metadata Extraction
ENABLE_AUTO_EXTRACTION=true
EXTRACTION_QUEUE=metadata_extraction

# Schema Validation
STRICT_SCHEMA_VALIDATION=true
MAX_SCHEMA_FIELDS=100

# File Processing Tools
FFPROBE_PATH=/usr/bin/ffprobe
EXIFTOOL_PATH=/usr/bin/exiftool

# Performance
MAX_BATCH_SIZE=100
REQUEST_TIMEOUT=30