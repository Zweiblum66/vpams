# Environment Configuration Template
# Copy this file to .env and update with your values

# Environment
ENVIRONMENT=development
DEBUG=true

# Database Configuration
DATABASE_URL=postgresql+asyncpg://mams:dev_password@localhost:5432/mams_dev
MONGODB_URL=mongodb://localhost:27017/mams
REDIS_URL=redis://localhost:6379/0
OPENSEARCH_URL=http://localhost:9200

# Storage Configuration
STORAGE_TYPE=s3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_ASSETS=mams-assets
S3_BUCKET_PROXIES=mams-proxies

# Message Queue
RABBITMQ_URL=amqp://mams:dev_password@localhost:5672/mams

# Security
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Service Ports
API_GATEWAY_PORT=8000
USER_MANAGEMENT_PORT=8001
STORAGE_SERVICE_PORT=8002
ASSET_SERVICE_PORT=8003
METADATA_SERVICE_PORT=8004
SEARCH_SERVICE_PORT=8005
INGEST_SERVICE_PORT=8006
PROXY_SERVICE_PORT=8007
WORKFLOW_SERVICE_PORT=8008
AI_SERVICE_PORT=8009
RIGHTS_SERVICE_PORT=8010
MONITORING_SERVICE_PORT=8011
INTEGRATION_SERVICE_PORT=8012

# Frontend
VITE_API_URL=http://localhost:8000/api/v1

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json